{
  "mcpServers": {
    "trigger": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "trigger.dev@latest",
        "mcp"
      ]
    },
    "sentry": {
      "type": "sse",
      "url": "https://mcp.sentry.dev/mcp/comp-ai/comp"
    },
    "trycompai": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@trycompai/design-system-mcp@latest"
      ]
    }
  }
}
