    "multer": "^2.2.0",
    "systeminformation": "^5.31.17",
    "tmp": "^0.2.7",
    "dompurify": "^3.4.12",
    "ip-address": "^10.2.0",
    "postcss": "^8.5.11",
    "prismjs": "^1.30.0",
    "qs": "^6.15.3",
    "effect": "^3.20.0",
    "protobufjs": "^7.6.3",
    "linkify-it": "^5.0.1",
    "mermaid": "^11.15.0",
    "shell-quote": "^1.8.4",
    "vite": "^6.4.3",
    "@opentelemetry/core": "^2.8.0",
    "@sigstore/core": "3.2.1",
    "markdown-it": "^14.3.0",
    "@babel/core": "^7.29.7",
    "uuid": "^11.1.1",
    "@tiptap/core": "3.22.1",
    "@tiptap/extension-blockquote": "3.22.1",
    "@tiptap/extension-bold": "3.22.1",
    "@tiptap/extension-bubble-menu": "3.22.1",
