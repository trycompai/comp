    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bun": "^1.3.14",
    "@types/d3": "^7.4.3",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ai": "^5.0.212",
    "concurrently": "^9.2.4",
    "d3": "^7.9.0",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-email": "^4.3.2",
    "react-hook-form": "^7.81.0",
    "semantic-release": "^25.0.7",
    "sharp": "^0.34.5",
    "syncpack": "^13.0.4",
    "tsup": "^8.5.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "use-debounce": "^10.1.1"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": "prettier --write"
  },
  "packageManager": "bun@1.3.4",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "check:env": "node scripts/check-unused-env.js",
    "check:prisma-schemas": "node scripts/check-generated-prisma-schemas.js",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "deploy:trigger-prod": "npx trigger.dev@4.4.3 deploy",
    "deps:check": "syncpack list-mismatches",
    "deps:dedupe": "syncpack fix-mismatches && bun install",
    "deps:fix": "syncpack fix-mismatches",
    "deps:lint": "syncpack lint",
    "deps:update": "syncpack update",
    "deps:upgrade": "syncpack update && bun install",
    "dev": "turbo dev --parallel",
    "db:generate": "turbo run db:generate --filter=@trycompai/db --filter=@trycompai/app --filter=@trycompai/portal --filter=@trycompai/api --filter=@trycompai/framework-editor",
    "docker:clean": "bun run -F @trycompai/db docker:clean",
    "docker:down": "bun run -F @trycompai/db docker:down",
    "docker:up": "bun run -F @trycompai/db docker:up",
    "format": "prettier --write .",
    "lint": "turbo lint && syncpack lint",
    "prepare": "husky",
    "test": "turbo test --parallel",
    "test:release": "node scripts/test-release.js",
    "typecheck": "turbo typecheck",
    "typecheck:ci": "turbo typecheck --filter={apps/**} --filter={packages/**} --filter=!@trycompai/integrations --filter=!@trycompai/ui"
  },
  "workspaces": [
    "apps/*",
    "!apps/mcp-server",
    "packages/*"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "3.1013.0",
    "@aws-sdk/s3-request-presigner": "3.1013.0",
    "@trycompai/design-system": "1.1.19",
    "@types/cheerio": "^1.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@upstash/vector": "^1.2.3",
    "better-auth": "^1.6.23",
    "cheerio": "^1.2.0",
    "react-syntax-highlighter": "^15.6.6",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "overrides": {
    "axios": "^1.16.0",
    "vitest": "^3.2.7",
    "@vitest/coverage-v8": "^3.2.7",
    "@vitest/ui": "^3.2.7",
    "form-data": "^4.0.6",
