/// Stores Browserbase context IDs for browser-based automation
/// One context per organization - shared like a normal browser
model BrowserbaseContext {
  id String @id @default(dbgenerated("generate_prefixed_cuid('bbc'::text)"))

  /// Organization that owns this browser context
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Browserbase context ID from their API
  contextId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

/// Auth state for one website identity backed by a Browserbase context.
/// Credentials and TOTP secrets are intentionally not stored here.
model BrowserAuthProfile {
  id String @id @default(dbgenerated("generate_prefixed_cuid('bap'::text)"))

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  hostname      String
  loginIdentity String @default("")
  displayName   String

  contextId        String
  status           BrowserAuthProfileStatus @default(unverified)
  lastVerifiedAt   DateTime?
  lastAuthCheckUrl String?
  blockedReason    String?

  vaultProvider        String?
  vaultExternalItemRef String?
  vaultConnectionId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs           BrowserAutomationRun[]
  automationSteps BrowserAutomationStep[]

  @@unique([organizationId, hostname, loginIdentity])
  @@index([organizationId])
  @@index([organizationId, hostname])
  @@index([status])
}

/// Browser automation configuration linked to a task
model BrowserAutomation {
  id          String  @id @default(dbgenerated("generate_prefixed_cuid('bau'::text)"))
  name        String
  description String?

  /// Task this automation belongs to
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Starting URL for the automation
  targetUrl String

  /// Natural language instruction for the AI agent
  instruction String

  /// Optional natural-language criteria used to evaluate whether the
  /// automation's outcome satisfies the auditor's requirement.
  /// When null, runs don't produce a pass/fail verdict — only a screenshot.
  evaluationCriteria String?

  /// Whether automation is enabled for scheduled runs
  isEnabled         Boolean       @default(false)
  scheduleFrequency TaskFrequency @default(daily)
  lastRunAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs  BrowserAutomationRun[]
  steps BrowserAutomationStep[]

  @@index([taskId])
}

/// Records of browser automation executions
model BrowserAutomationRun {
  id String @id @default(dbgenerated("generate_prefixed_cuid('bar'::text)"))

  /// Parent automation
  automationId String
  automation   BrowserAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  /// Auth profile/context used by this run
  profileId String?
  profile   BrowserAuthProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  /// Execution status
  status BrowserAutomationRunStatus @default(pending)

  /// Timestamps
  startedAt   DateTime?
  completedAt DateTime?

  /// Duration in milliseconds
  durationMs Int?

  /// Screenshot URL in S3 (if successful)
  screenshotUrl String?

  /// Evaluation result - whether the automation fulfilled the task requirements
  evaluationStatus BrowserAutomationEvaluationStatus?

  /// AI explanation of why it passed or failed
  evaluationReason String?

  /// Error message (if failed)
  error String?

  /// Stable failure metadata for retries, UI copy, and profile repair flows
  failureCode  BrowserAutomationFailureCode?
  failureStage BrowserAutomationFailureStage?
  attemptCount Int                            @default(1)
  blockedReason String?

  /// Final browser URL and structured execution events
  finalUrl String?
  logs     Json?

  createdAt DateTime @default(now())

  stepRuns BrowserAutomationStepRun[]

  @@index([automationId])
  @@index([profileId])
  @@index([status])
  @@index([failureCode])
  @@index([createdAt])
}

/// An in-progress (unsaved) automation the user is composing. Persisted
/// server-side so a draft survives refreshes and follows the user across
/// devices; it becomes a BrowserAutomation on save and is deleted then.
model BrowserAutomationDraft {
  id String @id @default(dbgenerated("generate_prefixed_cuid('bad'::text)"))

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  /// Member who last edited the draft (attribution / "your drafts").
  createdById String?

  /// Preview name, derived from the first step's instruction.
  name String?

  /// The composer state: an ordered array of
  /// { profileId, targetUrl, instruction, evaluationCriteria }.
  steps Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

/// One step of a (possibly multi-vendor) automation. Steps run in `order`, each
/// on its own connection's saved session, so a single automation can span
/// several vendors without re-logging in.
model BrowserAutomationStep {
  id String @id @default(dbgenerated("generate_prefixed_cuid('bas'::text)"))

  automationId String
  automation   BrowserAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  /// Position in the sequence (0-based).
  order Int

  /// Connection this step runs on. Nullable so removing a connection leaves the
  /// step in place (needing a re-bind) instead of deleting it.
  profileId String?
  profile   BrowserAuthProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  /// Starting URL for this step.
  targetUrl String

  /// Natural-language instruction for the AI agent on this step.
  instruction String

  /// Optional pass/fail criterion for this step. Null = capture only.
  evaluationCriteria String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stepRuns BrowserAutomationStepRun[]

  @@index([automationId])
  @@index([profileId])
}

/// Per-step result within one automation run (evidence + verdict per step).
model BrowserAutomationStepRun {
  id String @id @default(dbgenerated("generate_prefixed_cuid('basr'::text)"))

  runId String
  run   BrowserAutomationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  /// Step this result belongs to. Nullable so editing/removing a step doesn't
  /// delete historical run evidence.
  stepId String?
  step   BrowserAutomationStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  order Int

  status BrowserAutomationRunStatus @default(pending)

  screenshotUrl    String?
  evaluationStatus BrowserAutomationEvaluationStatus?
  evaluationReason String?
  error            String?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([runId])
  @@index([stepId])
}

enum BrowserAuthProfileStatus {
  unverified
  verified
  needs_reauth
  blocked
}

enum BrowserAutomationEvaluationStatus {
  pass
  fail
}

enum BrowserAutomationRunStatus {
  pending
  running
  completed
  failed
  blocked
}

enum BrowserAutomationFailureCode {
  needs_reauth
  needs_user_action
  rate_limited
  captcha_blocked
  timeout
  browser_session_lost
  evaluation_failed
  unknown
}

enum BrowserAutomationFailureStage {
  auth
  navigation
  action
  screenshot
  evaluation
  upload
  session
  unknown
}
