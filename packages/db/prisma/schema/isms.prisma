// ISMS Foundational Documents (ISO 27001 clauses 4.1-4.3, 5.1, 6.2)
//
// Generated-and-edited management-system documents that live alongside the SOA
// in the Documents page (Compliance -> Documents -> "ISO 27001 (ISMS)" tab).
// Mirrors the SOADocument pattern: links the global framework template
// (FrameworkEditorFramework) + organization, auto-fills from platform data,
// supports edit/override, versioning, sign-off, drift detection, and export.
//
// Each document maps 1:1 to its ISO 27001 clause requirement
// (FrameworkEditorRequirement) so it inherits framework grouping and powers the
// auditor "where is this clause evidenced?" link.

enum IsmsDocumentType {
  context_of_organization // 4.1
  interested_parties_register // 4.2a
  interested_parties_requirements // 4.2b / 4.2c
  isms_scope // 4.3
  leadership_commitment // 5.1
  roles_and_responsibilities // 5.3
  risk_assessment_methodology // 6.1.2
  risk_treatment_plan // 6.1.3
  objectives_plan // 6.2
  monitoring // 9.1
  internal_audit // 9.2
  management_review // 9.3
}

enum IsmsDocumentStatus {
  draft // being created / edited
  in_progress // being generated
  needs_review // submitted for approval
  approved // signed off
  declined // approval declined
}

model IsmsDocument {
  id String @id @default(dbgenerated("generate_prefixed_cuid('isms_doc'::text)"))

  // Framework + organization context. Mirrors SOADocument: references the global
  // framework template + the org, not the per-org FrameworkInstance.
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  frameworkId    String
  framework      FrameworkEditorFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  // ISO 27001 clause this document satisfies (4.1, 4.2, ...). Optional because the
  // clause requirement may not be seeded for every type until verified (e.g. 6.2).
  requirementId String?
  requirement   FrameworkEditorRequirement? @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  // Framework-editor template this document was instantiated from (CS-437).
  templateId String?
  template   FrameworkEditorIsmsDocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  type   IsmsDocumentType
  title  String
  status IsmsDocumentStatus @default(draft)

  // Approval / sign-off (mirrors SOADocument). These track the WORKING DRAFT's
  // approval lifecycle; the published version's own approver/date live on the
  // IsmsDocumentVersion row (publishedBy/publishedAt).
  preparedBy String    @default("Comp AI")
  approverId String?
  approver   Member?   @relation("IsmsDocumentApprover", fields: [approverId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  approvedAt DateTime?
  declinedAt DateTime?

  // Versioning (CS-701): mirrors the Policies model (Policy.currentVersionId +
  // draftContent). The live register tables + `draftNarrative` are the editable
  // DRAFT; `versions` holds immutable PUBLISHED snapshots; `currentVersion` is the
  // one that is live and exportable. Editing an approved document reverts `status`
  // to draft but never touches `currentVersion`, so v1 stays live while v2 is drafted.
  currentVersionId String?              @unique
  currentVersion   IsmsDocumentVersion? @relation("IsmsCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  // Working-draft narrative for the singleton documents (Scope 4.3, Leadership 5.1).
  // Register documents keep their draft in their own child tables. Replaces the old
  // `versions[0].narrative` draft-holder.
  draftNarrative   Json?
  // Drift baseline for the current draft: the derived platform inputs captured at
  // the last generate/approve. Replaces the old `versions[0].sourceSnapshot`.
  draftSnapshot    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  versions                    IsmsDocumentVersion[]            @relation("IsmsDocumentVersions")
  contextIssues               IsmsContextIssue[] // 4.1 register
  interestedParties           IsmsInterestedParty[] // 4.2a register
  interestedPartyRequirements IsmsInterestedPartyRequirement[] // 4.2b/c register
  objectives                  IsmsObjective[] // 6.2 register
  roles                       IsmsRole[] // 5.3 register (governance roles, responsibilities & authorities)
  metrics                     IsmsMetric[] // 9.1 register (monitoring & measurement framework)
  audits                      IsmsAudit[] // 9.2 register (internal audit programme, plan and report)
  reviews                     IsmsManagementReview[] // 9.3 register (management review procedure and minutes)
  controlLinks                IsmsDocumentControlLink[] // CS-437: org controls this document maps to

  @@unique([organizationId, frameworkId, type]) // one document per type per framework per org
  @@index([organizationId, type])
  @@index([frameworkId])
  @@index([requirementId])
  @@index([status])
}

// A partial unique index ("isms_document_version_one_latest") enforces at most one
// row with isLatest = true per documentId. Prisma cannot express a filtered unique
// index, so it lives in the raw SQL migration (isms_version_single_latest); keep it
// in sync if isLatest semantics change.
model IsmsDocumentVersion {
  id                 String        @id @default(dbgenerated("generate_prefixed_cuid('isms_ver'::text)"))
  documentId         String
  document           IsmsDocument  @relation("IsmsDocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  // Back-relation for IsmsDocument.currentVersion: set when this version is the
  // live/published one for its document.
  currentForDocument IsmsDocument? @relation("IsmsCurrentVersion")

  version  Int     @default(1)
  isLatest Boolean @default(true)

  // Frozen published narrative for the singleton documents (Scope, Leadership).
  // Empty ({}) for register documents, whose frozen content lives in contentSnapshot.
  narrative       Json
  // The full, immutable content snapshot of this published version: the rendered
  // export input (register rows + narrative + org profile) plus the export metadata
  // captured at publish. Lets a historical version be re-rendered byte-faithfully if
  // the stored file is ever missing. Null only for legacy/migrated versions.
  contentSnapshot Json?
  // Snapshot of derived platform inputs captured at publish, retained for the record
  // (the live drift baseline lives on IsmsDocument.draftSnapshot).
  sourceSnapshot  Json?

  // Rendered, branded exports retained per published version (S3 keys). Auditors
  // sampling an old version download exactly what was approved at the time.
  pdfUrl  String?
  docxUrl String?

  // The member who published (approved) this version, and when. `publishedAt != null`
  // is the marker of a published version (drafts are not materialized as rows).
  publishedById String?
  publishedBy   Member?   @relation("IsmsDocumentVersionPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt   DateTime?
  // Optional free-text note describing what changed in this version.
  changelog     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, version])
  @@index([documentId])
  @@index([documentId, isLatest])
  @@index([documentId, publishedAt])
}

// --- Register: Context of the Organization (clause 4.1) ---

enum IsmsContextIssueKind {
  internal
  external
}

// Shared across every ISMS register: distinguishes auto-derived rows from
// user-authored / overridden ones (the override is recorded by the flip to manual).
enum IsmsContextSource {
  derived // auto-populated from platform data
  manual // user-authored, or a derived value the user overrode (override recorded)
}

model IsmsContextIssue {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_ci'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  kind        IsmsContextIssueKind
  // ISO 27001 clause 4.1 grouping. External: "Regulatory & Legal" / "Market &
  // Economic" / "Technological" / "Social & Cultural". Internal: "Governance &
  // Structure" / "Strategy & Objectives" / "Capabilities & Resources" /
  // "Culture & Values". Nullable so legacy rows + free-form issues stay valid.
  category    String?
  description String // the internal / external issue
  effect      String // effect on the ISMS and its objectives (required by clause 4.1)

  source      IsmsContextSource @default(derived)
  derivedFrom String? // provenance for derived rows, e.g. "framework:iso27001", "vendor:<id>"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId, kind])
}

// --- ISMS wizard inputs (CS-438): the ~12 un-derivable answers that feed
// document generation. One profile per org + framework. Stored as a single
// Zod-validated JSON blob (configuration, not register rows). ---

model IsmsProfile {
  id             String                   @id @default(dbgenerated("generate_prefixed_cuid('isms_pf'::text)"))
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  frameworkId    String
  framework      FrameworkEditorFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  answers     Json // validated against the shared wizard Zod schema on read/write
  completedAt DateTime? // set when the customer finishes the wizard

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, frameworkId])
  @@index([organizationId])
}

// --- Register: Interested Parties (clause 4.2a) ---

model IsmsInterestedParty {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_ip'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  name              String // the interested party, e.g. "Customers", "Regulators (GDPR)", "Acme Cloud Ltd"
  category          String // grouping, e.g. "Customer", "Regulator", "Supplier", "Employee", "Shareholder"
  needsExpectations String // the party's relevant needs and expectations (4.2a)

  source      IsmsContextSource @default(derived)
  derivedFrom String? // e.g. "vendor:<id>", "framework:iso27001", "members"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requirements IsmsInterestedPartyRequirement[]

  @@index([documentId])
}

// --- Register: Interested Parties Requirements & ISMS Treatment (clauses 4.2b, 4.2c) ---

model IsmsInterestedPartyRequirement {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_ipr'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Optional link to a party from the Interested Parties Register. partyName is kept
  // denormalized so this register reads standalone even if the party row changes.
  interestedPartyId String?
  interestedParty   IsmsInterestedParty? @relation(fields: [interestedPartyId], references: [id], onDelete: SetNull)
  partyName         String

  requirement String // the party's requirement (4.2b)
  treatment   String // whether and how the ISMS addresses it (4.2c)

  source      IsmsContextSource @default(derived)
  derivedFrom String?

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([interestedPartyId])
}

// --- Register: Information Security Objectives (clause 6.2) ---

enum IsmsObjectiveStatus {
  not_started
  on_track
  at_risk
  met
}

model IsmsObjective {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_obj'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  objective         String // what we are trying to achieve (6.2)
  target            String? // measurable target / KPI
  ownerMemberId     String? // responsible member (plain id, like IsmsDocumentVersion.publishedById)
  cadence           String? // monitoring cadence, e.g. "Quarterly"
  plan              String? // what will be done, with what resources, by when (6.2)
  measurementMethod String? // how results are evaluated
  status            IsmsObjectiveStatus @default(not_started)

  source      IsmsContextSource @default(derived)
  derivedFrom String?

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Monitoring metrics (9.1) that use this objective as their target.
  metrics IsmsMetric[]

  @@index([documentId])
}

// --- Register: ISMS Governance Roles, Responsibilities & Authorities (clause 5.3) ---

// Basis on which an assigned member meets a role's required competence (clause 7.2).
enum IsmsCompetenceBasis {
  education
  training
  experience
  combination
}

// How the organization satisfies the internal-audit function (Internal Auditor role).
enum IsmsAuditRoute {
  in_house // an in-house person with ISO 27001 audit competence
  external // an external independent auditor engaged
  training_planned // internal auditor competence is being trained
}

model IsmsRole {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_role'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Stable key for the four seeded governance roles
  // ('top_management' | 'spo' | 'deputy_spo' | 'internal_auditor'); null for
  // customer-added custom roles. Seeding is idempotent on (documentId, roleKey).
  roleKey String?

  name               String // role title, e.g. "Security & Privacy Owner (SPO)"
  description        String // what the role is (pre-filled default, editable)
  responsibilities   String // the role's responsibilities (5.3)
  authorities        String // the role's authorities (5.3)
  authorityGrantedBy String // from whom the authority derives, e.g. "Top Management"
  requiredCompetence String // competence the role requires (7.2, role-level)

  // Internal Auditor route (only meaningful for the internal_auditor role).
  auditRoute         IsmsAuditRoute?
  auditRouteMemberId String? // in-house / training-planned member (plain id, like ownerMemberId)
  auditFirmName      String? // external: firm / person name
  auditEvidenceRef   String? // external: evidence reference, e.g. LA certificate
  auditCourse        String? // training planned: course name
  auditDueDate       DateTime? // training planned: target date

  source      IsmsContextSource @default(derived)
  derivedFrom String? // provenance for seeded rows, e.g. "seed:spo"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments IsmsRoleAssignment[]

  // Idempotency anchor for seedRolesIfMissing: at most one seeded role per key per
  // document. Custom roles have roleKey = null; Postgres treats NULLs as distinct,
  // so multiple custom roles per document remain allowed.
  @@unique([documentId, roleKey])
  @@index([documentId])
}

// A person assigned to an ISMS role, with their competence evidence (clause 7.2).
model IsmsRoleAssignment {
  id     String   @id @default(dbgenerated("generate_prefixed_cuid('isms_ra'::text)"))
  roleId String
  role   IsmsRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Denormalized document id so assignments can be listed org-scoped and mutated
  // through the generic register CRUD (mirrors IsmsInterestedPartyRequirement.documentId).
  documentId String

  memberId String // assigned member (plain id, like IsmsObjective.ownerMemberId)

  // Competence evidence (clause 7.2). All optional; the customer fills them in.
  basisOfCompetence  IsmsCompetenceBasis?
  evidenceRetained   String?
  gap                String? // optional competence gap
  remediationAction  String? // shown only when a gap is set
  remediationDueDate DateTime?

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, memberId]) // one assignment per member per role
  @@index([roleId])
  @@index([documentId])
}

// --- Register: Monitoring, Measurement, Analysis & Evaluation (clause 9.1) ---

// How often a metric's value is recorded. Each cadence maps to a calendar
// period ("period covered"): monthly = calendar month, quarterly = calendar
// quarter. Deliberately small in v1 — extend additively if a customer needs
// annual or ad-hoc rhythms.
enum IsmsMetricCadence {
  monthly
  quarterly
}

// A monitored metric (clause 9.1 a-f: what is measured, how, when, by whom,
// who analyses). Nine defaults are seeded per document (seed-if-missing by
// metricKey, mirroring IsmsRole.roleKey); customers edit them, deactivate
// them, or add custom metrics.
model IsmsMetric {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_met'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Stable key for the nine seeded metrics (e.g. 'training_completion');
  // null for customer-added custom metrics. Seeding is idempotent on
  // (documentId, metricKey); NULLs stay distinct so many customs are allowed.
  metricKey String?

  name           String // short title, e.g. "Security awareness training completion"
  whatIsMeasured String // clause 9.1(a): what is measured (pre-filled, editable)
  method         String // clause 9.1(b): how the value is derived (pre-filled, editable)
  // Nullable so a custom metric can be drafted without one; the clause-9.1
  // submit gate requires a cadence on every ACTIVE metric.
  cadence        IsmsMetricCadence?

  // Clause 9.1(c)/(e): who monitors and who analyses. Plain member ids (like
  // IsmsObjective.ownerMemberId — no FK; names are resolved at export time).
  // Seeded to the SPO for 1-3 person orgs, left unassigned for 4+.
  monitorMemberId String?
  analyzeMemberId String?

  // The target the metric is evaluated against: free text and/or a link to an
  // Objective from the Objectives Plan (6.2), whose own target then applies.
  target      String?
  objectiveId String?
  objective   IsmsObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)

  // Where measurement VALUES come from. Always 'manual' in v1; reserved for
  // integration identifiers later (schema accepts them without UI change).
  // Distinct from `source` below, which tracks row provenance (seeded vs
  // user-authored) like every other ISMS register.
  dataSource String @default("manual")

  // Deactivating is the honest "remove" for seeded metrics: history is kept,
  // the seed never resurrects the row, and overdue tracking stops. Custom
  // metrics may also be hard-deleted.
  isActive Boolean @default(true)

  source      IsmsContextSource @default(derived)
  derivedFrom String? // provenance for seeded rows, e.g. "seed:training_completion"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  measurements IsmsMeasurement[]

  @@unique([documentId, metricKey])
  @@index([documentId])
}

// One recorded value for a metric. Append-style history, never an overwrite:
// each period's value is its own timestamped row, and re-entering a period
// adds a correction row rather than mutating the old one. `recordedAt` and
// `enteredById` are server-set and immutable — the guardrail that keeps
// backfill honest (a late entry shows its true recording date).
model IsmsMeasurement {
  id       String     @id @default(dbgenerated("generate_prefixed_cuid('isms_msr'::text)"))
  metricId String
  metric   IsmsMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  // Denormalized document id so measurements can be listed org-scoped and
  // mutated through the generic register CRUD (mirrors IsmsRoleAssignment).
  documentId String

  // First day (UTC) of the period the value covers: the 1st of the month for
  // monthly cadence, the 1st of Jan/Apr/Jul/Oct for quarterly. Distinct from
  // recordedAt — backfilled rows carry a historical period with today's
  // recording date.
  periodStart DateTime @db.Date

  value String // the number or short text the customer entered
  note  String? // optional context, e.g. explanation of an anomaly

  // Server-set at creation, never updatable (the audit-honesty guardrail).
  recordedAt  DateTime @default(now())
  enteredById String? // recording member (plain id, like IsmsObjective.ownerMemberId)

  // 'manual' in v1; reserved for integration identifiers later.
  source String @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([metricId, periodStart])
  @@index([documentId])
}

// --- Register: Internal Audit Programme, Plan & Report (clause 9.2) ---

enum IsmsAuditStatus {
  planned
  in_progress
  complete
}

// The bracketed choice in the audit conclusion template: "...found the ISMS to
// [conform / substantially conform with the non-conformities recorded below /
// not yet conform] to ISO/IEC 27001:2022."
enum IsmsAuditConclusionVerdict {
  conform
  substantially_conform
  not_yet_conform
}

// The auditor's finding for one sampled control (Controls Tested row).
enum IsmsAuditControlResult {
  conformity_confirmed
  nonconformity_raised
  observation_raised
  not_sampled // deliberately scoped out this cycle (still rendered in the doc)
}

enum IsmsAuditFindingType {
  nc_major
  nc_minor
  ofi // opportunity for improvement
  observation
}

enum IsmsAuditFindingStatus {
  open
  in_progress
  closed
}

// One internal audit instance (clause 9.2). The v1 shape is one annual full
// audit; every field ships with auditor-defensible template text the customer
// can accept or edit. All values are typed in by the customer (manual-first);
// the schema accepts later automation without a UI change.
model IsmsAudit {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_aud'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Server-generated "IA-YYYY-NN" (year of creation, per-document sequence).
  reference String
  scope     String
  criteria  String

  // The auditor as a display string ("Sarah Chen, Assured Compliance Ltd").
  // Free text, frozen at selection: the UI offers the Internal Auditor holder
  // from ISMS > Roles (5.3) — a member or an external firm — but the audit
  // record must keep the name that performed THIS audit even if Roles changes.
  auditorName String?

  plannedStartDate DateTime?       @db.Date
  plannedEndDate   DateTime?       @db.Date
  status           IsmsAuditStatus @default(planned)

  // Conclusion: the customer picks the bracketed verdict and may add narrative.
  conclusionVerdict IsmsAuditConclusionVerdict?
  conclusionNotes   String?

  // Sign-off: three signature slots per audit (auditor / SPO / top management).
  // Names are free text (external auditors are not members); a slot is "signed"
  // when both its name and date are set. Rendered as the document's sign-off
  // table and frozen into the version contentSnapshot at publish.
  signoffAuditorName    String?
  signoffAuditorDate    DateTime? @db.Date
  signoffSpoName        String?
  signoffSpoDate        DateTime? @db.Date
  signoffTopMgmtName    String?
  signoffTopMgmtDate    DateTime? @db.Date

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  controls IsmsAuditControl[]
  findings IsmsAuditFinding[]

  // References are generated under the per-document lock, so this never fires
  // in practice; it keeps concurrent creates honest at the database layer.
  @@unique([documentId, reference])
  @@index([documentId])
}

// One sampled control in an audit's Controls Tested table. Fifteen default
// rows are seeded per audit (seed-if-missing by controlKey, mirroring
// IsmsMetric.metricKey); the customer/auditor fills in Result and Notes, and
// may add, edit, or remove rows freely.
model IsmsAuditControl {
  id      String    @id @default(dbgenerated("generate_prefixed_cuid('isms_ac'::text)"))
  auditId String
  audit   IsmsAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  // Denormalized document id so control rows can be listed org-scoped and
  // mutated through the generic register CRUD (mirrors IsmsRoleAssignment).
  documentId String

  // Stable key for the fifteen seeded rows (e.g. 'clause_4_1_context');
  // null for customer-added rows. Seeding is idempotent on (auditId,
  // controlKey); NULLs stay distinct so many custom rows are allowed.
  controlKey String?

  controlRef    String // e.g. "Clause 4.1 Context" / "A.8.13 Backup"
  whatWasTested String // short description of what the control covers
  // Pre-filled with a "Comp AI > ..." location; free text so the customer can
  // point at an external location when evidence lives outside Comp AI.
  whereToFind   String

  // Null until the auditor records an outcome for the row.
  result IsmsAuditControlResult?
  notes  String? // external evidence, dates, or auditor commentary

  source      IsmsContextSource @default(derived)
  derivedFrom String? // provenance for seeded rows, e.g. "seed:clause_4_1_context"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Findings raised against this control row (link survives row edits; the
  // finding keeps its own clauseOrControl text as the frozen label).
  findings IsmsAuditFinding[]

  @@unique([auditId, controlKey])
  @@index([auditId])
  @@index([documentId])
}

// A non-conformity, opportunity for improvement, or observation raised during
// an audit. Most findings are created from a Controls Tested row (result
// non-conformity/observation); standalone findings are also allowed.
model IsmsAuditFinding {
  id      String    @id @default(dbgenerated("generate_prefixed_cuid('isms_af'::text)"))
  auditId String
  audit   IsmsAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)

  // Denormalized document id for org-scoped generic register CRUD.
  documentId String

  // Server-generated "F-NN" (per-audit sequence).
  reference String

  type IsmsAuditFindingType

  // Optional link back to the Controls Tested row that raised this finding.
  controlId String?
  control   IsmsAuditControl? @relation(fields: [controlId], references: [id], onDelete: SetNull)

  // Free text; pre-fills from the linked control row's reference in the UI.
  clauseOrControl String?
  description     String

  ownerMemberId String? // responsible member (plain id, like IsmsObjective.ownerMemberId)
  dueDate       DateTime? @db.Date

  status          IsmsAuditFindingStatus @default(open)
  closureEvidence String? // free text or link

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([auditId, reference])
  @@index([auditId])
  @@index([documentId])
  @@index([controlId])
}

// --- Register: Management Review Procedure & Minutes (clause 9.3) ---

enum IsmsReviewStatus {
  planned
  in_progress
  complete
}

// The bracketed choice in the review conclusion template: "The information
// security management system was reviewed on [meeting date]. Overall, the ISMS
// was found to be [suitable / adequate / effective] and no changes are required
// except those recorded in the outputs section below."
enum IsmsReviewConclusionVerdict {
  suitable
  adequate
  effective
}

enum IsmsReviewActionStatus {
  open
  in_progress
  closed
}

// One management review instance (clause 9.3). Annual plus ad-hoc cadence by
// default; every text field ships with auditor-defensible template text the
// customer can accept or edit. Manual-first: all values are typed in by the
// customer, with the same schema shape as Monitoring so later auto-population
// of the Inputs table needs no schema change.
model IsmsManagementReview {
  id         String       @id @default(dbgenerated("generate_prefixed_cuid('isms_mr'::text)"))
  documentId String
  document   IsmsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Server-generated "MR-YYYY-NN" (year of creation, per-document sequence).
  reference String

  // The date the review was actually held (customer-entered; may be backdated).
  meetingDate DateTime? @db.Date

  // Server-set at creation, never updatable — the same audit-honesty guardrail
  // as IsmsMeasurement.recordedAt: a backdated meeting still shows its true
  // recording date ("Recorded on" in the UI and document).
  recordedAt DateTime @default(now())

  // The chair as a display string, offered from the ISMS > Roles (5.3) Top
  // Management holder and frozen at selection (auditorName precedent: the
  // minutes must keep the name that chaired THIS review even if Roles changes).
  chairName String?

  // Attendees frozen at selection: array of { memberId, name } objects
  // (memberId a plain id like IsmsObjective.ownerMemberId). Defaults to
  // Chair + SPO at creation; for 1-3 person orgs these may be the same person.
  attendees Json @default("[]")

  status IsmsReviewStatus @default(planned)

  // Conclusion: the customer picks the bracketed verdict and may add narrative.
  conclusionVerdict IsmsReviewConclusionVerdict?
  conclusionNotes   String?

  // Outputs (9.3.3): both ship with default template text seeded at creation.
  decisionsText String?
  changesText   String?

  // Sign-off: a single signature slot — the chair signs (name free text, same
  // rationale as chairName). A review is "signed" when both name and date are
  // set; once signed the instance is locked (actions still track to closure).
  signoffChairName String?
  signoffChairDate DateTime? @db.Date

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inputs  IsmsReviewInput[]
  actions IsmsReviewAction[]

  // References are generated under the per-document lock, so this never fires
  // in practice; it keeps concurrent creates honest at the database layer.
  @@unique([documentId, reference])
  @@index([documentId])
}

// One row in a review's Inputs (9.3.2) table — the meeting agenda. Ten default
// rows are seeded per review (seed-if-missing by inputKey, mirroring
// IsmsAuditControl.controlKey): inputs (a) through (g) with (d) split into its
// four sub-inputs. The customer adds discussion notes during the meeting and
// ticks Discussed?; rows may be added, edited, or removed freely.
model IsmsReviewInput {
  id       String               @id @default(dbgenerated("generate_prefixed_cuid('isms_mri'::text)"))
  reviewId String
  review   IsmsManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  // Denormalized document id so input rows can be listed org-scoped and
  // mutated through the generic register CRUD (mirrors IsmsAuditControl).
  documentId String

  // Stable key for the ten seeded rows (e.g. 'a_prior_actions'); null for
  // customer-added rows. Seeding is idempotent on (reviewId, inputKey);
  // NULLs stay distinct so many custom rows are allowed.
  inputKey String?

  inputRef     String // e.g. "(a) Prior actions" / "(d.2) Monitoring results"
  whatItCovers String // what the ISO-mandated input covers (pre-filled, editable)
  // Pre-filled with a "Comp AI > ..." location; free text so the customer can
  // point at an external location when evidence lives outside Comp AI.
  whereToFind  String

  discussionNotes String? // filled during the meeting — the minutes for this input
  discussed       Boolean @default(false)

  source      IsmsContextSource @default(derived)
  derivedFrom String? // provenance for seeded rows, e.g. "seed:a_prior_actions"

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewId, inputKey])
  @@index([reviewId])
  @@index([documentId])
}

// An action arising from a management review (9.3.3 outputs). Open actions
// carry forward automatically to the next review's input (a) — computed from
// prior reviews at display/export time, never copied. Action tracking stays
// editable after the review is signed (actions track to closure).
model IsmsReviewAction {
  id       String               @id @default(dbgenerated("generate_prefixed_cuid('isms_mra'::text)"))
  reviewId String
  review   IsmsManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  // Denormalized document id for org-scoped generic register CRUD.
  documentId String

  // Server-generated "A01" (per-review sequence); rendered with the review
  // reference as "MR-YYYY-NN-A01" in the UI and document.
  reference String

  description   String
  ownerMemberId String? // responsible member (plain id, like IsmsObjective.ownerMemberId)
  dueDate       DateTime? @db.Date

  status IsmsReviewActionStatus @default(open)

  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reviewId, reference])
  @@index([reviewId])
  @@index([documentId])
}

// --- Org-level link: an ISMS document maps to individual controls (CS-437) ---
// Direct document<->control junction (both are org-scoped), mirroring how the
// platform links documents to controls (cf. ControlDocumentType). The app doc
// detail page manages these like Policy control mappings.
model IsmsDocumentControlLink {
  id             String       @id @default(dbgenerated("generate_prefixed_cuid('idc'::text)"))
  ismsDocumentId String
  ismsDocument   IsmsDocument @relation(fields: [ismsDocumentId], references: [id], onDelete: Cascade)
  controlId      String
  control        Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([ismsDocumentId, controlId])
  @@index([ismsDocumentId])
  @@index([controlId])
}
