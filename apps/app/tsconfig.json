{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@db": [
        "./prisma"
      ],
      "@/trigger": [
        "./src/trigger"
      ],
      "@/trigger/*": [
        "./src/trigger/*"
      ],
      "@trycompai/ui/hooks": [
        "../../packages/ui/src/hooks/index.ts"
      ],
      "@trycompai/ui/hooks/*": [
        "../../packages/ui/src/hooks/*"
      ],
      "@trycompai/ui/utils/*": [
        "../../packages/ui/src/utils/*"
      ],
      "@trycompai/ui/cn": [
        "../../packages/ui/src/utils/cn.ts"
      ],
      "@trycompai/ui/truncate": [
        "../../packages/ui/src/utils/truncate.ts"
      ],
      "@trycompai/ui/editor": [
        "../../packages/ui/src/components/editor/index.tsx"
      ],
      "@trycompai/ui/globals.css": [
        "../../packages/ui/src/globals.css"
      ],
      "@trycompai/ui/editor.css": [
        "../../packages/ui/src/editor.css"
      ],
      "@trycompai/ui/tailwind.config": [
        "../../packages/ui/tailwind.config.ts"
      ],
      "@trycompai/email/emails/*": [
        "../../packages/email/emails/*"
      ],
      "@trycompai/email/lib/*": [
        "../../packages/email/lib/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "trigger.config.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
